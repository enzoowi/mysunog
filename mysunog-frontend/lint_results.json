[{"filePath":"C:\\Users\\Brian\\Desktop\\mysunog\\mysunog-frontend\\src\\App.tsx","messages":[{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\nC:\\Users\\Brian\\Desktop\\mysunog\\mysunog-frontend\\src\\App.tsx:92:21\n  90 |   }\n  91 |\n> 92 |   useEffect(() => { fetchUnreadCount(); }, []);\n     |                     ^^^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  93 |\n  94 |   return (\n  95 |     <div className=\"min-h-screen bg-gray-50\">","line":92,"column":21,"nodeType":null,"endLine":92,"endColumn":37}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { Link, Route, Routes, useLocation, useNavigate } from 'react-router-dom';\nimport { useEffect, useState } from 'react';\nimport { api } from './services/api';\nimport { Flame, ChevronDown, Bell } from 'lucide-react';\n\nimport Home from './pages/Home';\nimport ChatbotWidget from './components/ChatbotWidget';\n\nimport Login from './pages/Login';\nimport PermitSubmit from './pages/PermitSubmit';\nimport MyPermits from './pages/MyPermits';\nimport AdminPermits from './pages/AdminPermits';\nimport Notifications from './pages/Notifications';\nimport IncidentCreate from './pages/IncidentCreate';\nimport IncidentList from './pages/IncidentList';\nimport IncidentDashboard from './pages/IncidentDashboard';\nimport IncidentMap from './pages/IncidentMap';\nimport InspectionRequest from './pages/InspectionRequest';\nimport AdminInspections from './pages/AdminInspections';\nimport AdminAlerts from './pages/AdminAlerts';\nimport AdminEducation from './pages/AdminEducation';\nimport HazardReport from './pages/HazardReport';\nimport AdminHazards from './pages/AdminHazards';\nimport VolunteerRegister from './pages/VolunteerRegister';\nimport Reports from './pages/Reports';\nimport AdminDashboard from './pages/AdminDashboard';\n\nexport default function App() {\n  const [unreadCount, setUnreadCount] = useState(0);\n  const [menuOpen, setMenuOpen] = useState(false);\n  const [servicesOpen, setServicesOpen] = useState(false);\n  const [activeTab, setActiveTab] = useState('');\n  const location = useLocation();\n  const navigate = useNavigate();\n\n  // Scroll spy logic\n  useEffect(() => {\n    const handleScroll = () => {\n      const sections = ['alerts', 'education', 'map', 'hotlines'];\n      let current = '';\n      for (const section of sections) {\n        const element = document.getElementById(section);\n        if (element) {\n          const rect = element.getBoundingClientRect();\n          // Adjust threshold based on typical header heights\n          if (rect.top <= 200 && rect.bottom >= 200) {\n            current = section;\n          }\n        }\n      }\n      if (current !== activeTab) setActiveTab(current);\n    };\n\n    window.addEventListener('scroll', handleScroll);\n    return () => window.removeEventListener('scroll', handleScroll);\n  }, [activeTab]);\n\n  // Scroll to hash when necessary\n  useEffect(() => {\n    if (location.hash) {\n      setTimeout(() => {\n        const element = document.getElementById(location.hash.substring(1));\n        if (element) {\n          element.scrollIntoView({ behavior: 'smooth' });\n        }\n      }, 100);\n    } else {\n        window.scrollTo({ top: 0, behavior: 'instant' });\n    }\n  }, [location]);\n\n  const handleNavClick = (hash: string) => {\n      setMenuOpen(false);\n      setServicesOpen(false);\n      if (location.pathname === '/') {\n          const element = document.getElementById(hash.substring(1));\n          if (element) element.scrollIntoView({ behavior: 'smooth' });\n      } else {\n          navigate(hash);\n      }\n  };\n\n  async function fetchUnreadCount() {\n    try {\n      const token = localStorage.getItem('token');\n      if (!token) { setUnreadCount(0); return; }\n      const res = await api.get('/notifications/unread-count');\n      setUnreadCount(res.data.count);\n    } catch { setUnreadCount(0); }\n  }\n\n  useEffect(() => { fetchUnreadCount(); }, []);\n\n  return (\n    <div className=\"min-h-screen bg-gray-50\">\n      {/* Navigation Bar */}\n      <nav className=\"bg-white border-b border-gray-200 shadow-sm sticky top-0 z-50\">\n        <div className=\"max-w-7xl mx-auto px-4\">\n          <div className=\"flex items-center h-16\">\n            <Link to=\"/\" className=\"flex items-center gap-2 z-50\">\n              <Flame className=\"w-8 h-8 text-orange-600\" />\n              <span className=\"font-bold text-xl text-gray-800\">mySunog</span>\n            </Link>\n\n            <div className={`${menuOpen ? 'block absolute top-16 left-0 right-0 bg-white border-b shadow-lg p-4' : 'hidden'} md:flex md:items-center md:mx-auto`}>\n              <div className=\"flex flex-col md:flex-row md:items-center gap-1 md:gap-2\">\n                {/* Citizen Section */}\n                <span className=\"text-xs text-gray-400 font-semibold uppercase tracking-wide px-3 py-1 md:hidden\">Citizen</span>\n                <button onClick={() => handleNavClick('/#alerts')} className={`px-3 py-2 text-sm rounded-lg transition text-left font-medium ${activeTab === 'alerts' ? 'bg-orange-50 text-orange-600' : 'text-gray-700 hover:bg-orange-50 hover:text-orange-600'}`}>Alerts</button>\n                <button onClick={() => handleNavClick('/#education')} className={`px-3 py-2 text-sm rounded-lg transition text-left font-medium ${activeTab === 'education' ? 'bg-orange-50 text-orange-600' : 'text-gray-700 hover:bg-orange-50 hover:text-orange-600'}`}>Education</button>\n                <button onClick={() => handleNavClick('/#map')} className={`px-3 py-2 text-sm rounded-lg transition text-left font-medium ${activeTab === 'map' ? 'bg-orange-50 text-orange-600' : 'text-gray-700 hover:bg-orange-50 hover:text-orange-600'}`}>Map</button>\n                <button onClick={() => handleNavClick('/#hotlines')} className={`px-3 py-2 text-sm rounded-lg transition text-left font-medium ${activeTab === 'hotlines' ? 'bg-orange-50 text-orange-600' : 'text-gray-700 hover:bg-orange-50 hover:text-orange-600'}`}>Hotlines</button>\n                <Link to=\"/hazard-report\" className=\"px-3 py-2 text-sm text-gray-700 hover:bg-orange-50 hover:text-orange-600 rounded-lg transition font-medium\" onClick={() => setMenuOpen(false)}>Report Hazard</Link>\n                \n                {/* Dropdown for Services */}\n                <div className=\"relative group\" \n                     onMouseEnter={() => setServicesOpen(true)} \n                     onMouseLeave={() => setServicesOpen(false)}>\n                    <button className=\"flex items-center gap-1 px-3 py-2 text-sm text-gray-700 hover:bg-orange-50 hover:text-orange-600 rounded-lg transition w-full md:w-auto font-medium\"\n                            onClick={() => setServicesOpen(!servicesOpen)}>\n                        Services <ChevronDown className=\"w-4 h-4\" />\n                    </button>\n                    \n                    {/* Dropdown Menu */}\n                    <div className={`${servicesOpen ? 'block' : 'hidden'} md:absolute left-0 top-full mt-1 w-48 bg-white md:shadow-xl md:border border-gray-100 rounded-xl overflow-hidden z-[1001] transition-all ml-4 md:ml-0`}>\n                        <Link to=\"/submit\" className=\"flex items-center px-4 py-3 text-sm text-gray-700 hover:bg-orange-50 hover:text-orange-600 transition\" onClick={() => {setMenuOpen(false); setServicesOpen(false);}}>\n                            <FileTextIcon /> \n                            <span className=\"ml-2\">Apply for Permit</span>\n                        </Link>\n                        <Link to=\"/inspections/request\" className=\"flex items-center px-4 py-3 text-sm text-gray-700 hover:bg-orange-50 hover:text-orange-600 transition border-t border-gray-50\" onClick={() => {setMenuOpen(false); setServicesOpen(false);}}>\n                            <SettingsIcon />\n                            <span className=\"ml-2\">Request Inspection</span>\n                        </Link>\n                    </div>\n                </div>\n\n                <div className=\"hidden md:block w-px h-6 bg-gray-200 mx-2\" />\n\n                {/* User Section */}\n                <span className=\"text-xs text-gray-400 font-semibold uppercase tracking-wide px-3 py-1 md:hidden mt-4\">Account</span>\n                <Link to=\"/mine\" className=\"px-3 py-2 text-sm text-gray-700 hover:bg-orange-50 hover:text-orange-600 rounded-lg transition font-medium\" onClick={() => setMenuOpen(false)}>My Permits</Link>\n                <Link to=\"/admin/dashboard\" className=\"px-3 py-2 text-sm text-orange-600 font-bold hover:bg-orange-50 rounded-lg transition\" onClick={() => setMenuOpen(false)}>Admin</Link>\n                <Link to=\"/login\" className=\"px-3 py-2 text-sm text-gray-700 hover:bg-orange-50 hover:text-orange-600 rounded-lg transition font-medium\" onClick={() => setMenuOpen(false)}>Login</Link>\n              </div>\n            </div>\n\n            {/* Always visible top-right section */}\n            <div className=\"flex items-center gap-2 ml-auto z-50\">\n              <Link to=\"/notifications\" className=\"p-2 relative text-gray-500 hover:text-orange-600 transition\" title=\"Notifications\" onClick={() => setMenuOpen(false)}>\n                <Bell className=\"w-6 h-6\" />\n                {unreadCount > 0 && (\n                  <span className=\"absolute top-1.5 right-1.5 bg-red-500 text-white text-[9px] min-w-[16px] h-4 flex items-center justify-center rounded-full font-bold px-1 border-2 border-white\">{unreadCount}</span>\n                )}\n              </Link>\n              <button onClick={() => setMenuOpen(!menuOpen)} className=\"md:hidden p-2 text-gray-600\">\n                <span className=\"text-2xl\">{menuOpen ? '✕' : '☰'}</span>\n              </button>\n            </div>\n          </div>\n        </div>\n      </nav>\n\n      {/* Routes */}\n      <main className=\"max-w-7xl mx-auto flex-1 w-full\">\n        <Routes>\n          <Route path=\"/\" element={<Home />} />\n          <Route path=\"/login\" element={<Login />} />\n\n          {/* Citizen routes */}\n          <Route path=\"/submit\" element={<PermitSubmit />} />\n          <Route path=\"/mine\" element={<MyPermits />} />\n          <Route path=\"/inspections/request\" element={<InspectionRequest />} />\n          <Route path=\"/hazard-report\" element={<HazardReport />} />\n          <Route path=\"/volunteer\" element={<VolunteerRegister />} />\n          <Route path=\"/notifications\" element={<Notifications />} />\n\n          {/* Incident routes */}\n          <Route path=\"/incidents/create\" element={<IncidentCreate />} />\n          <Route path=\"/incidents/list\" element={<IncidentList />} />\n          <Route path=\"/incidents/dashboard\" element={<IncidentDashboard />} />\n          <Route path=\"/incidents/map\" element={<IncidentMap />} />\n\n          {/* Admin routes */}\n          <Route path=\"/admin/dashboard\" element={<AdminDashboard />} />\n          <Route path=\"/admin/permits\" element={<AdminPermits />} />\n          <Route path=\"/admin/inspections\" element={<AdminInspections />} />\n          <Route path=\"/admin/alerts\" element={<AdminAlerts />} />\n          <Route path=\"/admin/education\" element={<AdminEducation />} />\n          <Route path=\"/admin/hazards\" element={<AdminHazards />} />\n          <Route path=\"/reports\" element={<Reports />} />\n        </Routes>\n      </main>\n\n      {/* Floating Chatbot Widget Wrapper (rendered on all pages) */}\n      <ChatbotWidget />\n    </div>\n  );\n}\n\n// Inline mini-icons for dropdown since they needed to be rendered neatly.\nfunction FileTextIcon() { return <svg className=\"w-4 h-4\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2\" strokeLinecap=\"round\" strokeLinejoin=\"round\"><path d=\"M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z\"/><polyline points=\"14 2 14 8 20 8\"/><line x1=\"16\" y1=\"13\" x2=\"8\" y2=\"13\"/><line x1=\"16\" y1=\"17\" x2=\"8\" y2=\"17\"/><line x1=\"10\" y1=\"9\" x2=\"8\" y2=\"9\"/></svg>; }\nfunction SettingsIcon() { return <svg className=\"w-4 h-4\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2\" strokeLinecap=\"round\" strokeLinejoin=\"round\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/><line x1=\"12\" y1=\"8\" x2=\"12\" y2=\"12\"/><line x1=\"12\" y1=\"16\" x2=\"12.01\" y2=\"16\"/></svg>; }","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Brian\\Desktop\\mysunog\\mysunog-frontend\\src\\components\\ChatbotWidget.tsx","messages":[{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\nC:\\Users\\Brian\\Desktop\\mysunog\\mysunog-frontend\\src\\components\\ChatbotWidget.tsx:10:9\n   8 |\n   9 |     useEffect(() => {\n> 10 |         setHasMounted(true);\n     |         ^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  11 |     }, []);\n  12 |\n  13 |     if (!hasMounted) return null;","line":10,"column":9,"nodeType":null,"endLine":10,"endColumn":22}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState, useEffect } from 'react';\nimport { MessageCircle, X } from 'lucide-react';\nimport Chatbot from '../pages/Chatbot';\n\nexport default function ChatbotWidget() {\n    const [isOpen, setIsOpen] = useState(false);\n    const [hasMounted, setHasMounted] = useState(false);\n\n    useEffect(() => {\n        setHasMounted(true);\n    }, []);\n\n    if (!hasMounted) return null;\n\n    return (\n        <div className=\"fixed bottom-6 right-6 z-[1000] flex flex-col items-end\">\n            {/* Chat popover */}\n            {isOpen && (\n                <div className=\"mb-4 bg-white rounded-2xl shadow-2xl border border-gray-200 overflow-hidden flex flex-col transition-all duration-300 transform origin-bottom-right\"\n                    style={{ width: '350px', height: '500px', maxWidth: 'calc(100vw - 32px)' }}>\n                    <div className=\"absolute top-2 right-2 z-10\">\n                        <button\n                            onClick={() => setIsOpen(false)}\n                            className=\"p-1 rounded-full bg-gray-100/80 text-gray-500 hover:bg-gray-200 hover:text-gray-800 transition backdrop-blur-sm\"\n                        >\n                            <X className=\"w-4 h-4\" />\n                        </button>\n                    </div>\n                    {/* The Chatbot component is now fully responsive and handles its own layout */}\n                    <Chatbot />\n                </div>\n            )}\n\n            {/* Toggle button */}\n            <button\n                onClick={() => setIsOpen(!isOpen)}\n                className={`flex items-center justify-center rounded-full shadow-lg transition-transform duration-300 hover:scale-110 ${isOpen ? 'bg-gray-800 text-white w-12 h-12' : 'bg-orange-600 text-white w-14 h-14 hover:bg-orange-700'\n                    }`}\n                aria-label=\"Toggle Chat\"\n            >\n                {isOpen ? <X className=\"w-6 h-6\" /> : <MessageCircle className=\"w-7 h-7\" />}\n            </button>\n        </div>\n    );\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Brian\\Desktop\\mysunog\\mysunog-frontend\\src\\components\\MapView.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Brian\\Desktop\\mysunog\\mysunog-frontend\\src\\firebase.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Brian\\Desktop\\mysunog\\mysunog-frontend\\src\\main.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Brian\\Desktop\\mysunog\\mysunog-frontend\\src\\pages\\AdminAlerts.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Brian\\Desktop\\mysunog\\mysunog-frontend\\src\\pages\\AdminDashboard.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Brian\\Desktop\\mysunog\\mysunog-frontend\\src\\pages\\AdminEducation.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Brian\\Desktop\\mysunog\\mysunog-frontend\\src\\pages\\AdminHazards.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Brian\\Desktop\\mysunog\\mysunog-frontend\\src\\pages\\AdminInspections.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Brian\\Desktop\\mysunog\\mysunog-frontend\\src\\pages\\AdminPermits.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Brian\\Desktop\\mysunog\\mysunog-frontend\\src\\pages\\Alerts.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Brian\\Desktop\\mysunog\\mysunog-frontend\\src\\pages\\Chatbot.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Brian\\Desktop\\mysunog\\mysunog-frontend\\src\\pages\\EducationHub.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Brian\\Desktop\\mysunog\\mysunog-frontend\\src\\pages\\EmergencyHotlines.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Brian\\Desktop\\mysunog\\mysunog-frontend\\src\\pages\\HazardReport.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Brian\\Desktop\\mysunog\\mysunog-frontend\\src\\pages\\Home.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Brian\\Desktop\\mysunog\\mysunog-frontend\\src\\pages\\IncidentCreate.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Brian\\Desktop\\mysunog\\mysunog-frontend\\src\\pages\\IncidentDashboard.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Brian\\Desktop\\mysunog\\mysunog-frontend\\src\\pages\\IncidentList.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Brian\\Desktop\\mysunog\\mysunog-frontend\\src\\pages\\IncidentMap.tsx","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":8,"column":37,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":8,"endColumn":40,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[367,370],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[367,370],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useEffect, useMemo, useState } from 'react';\nimport { api } from '../services/api';\nimport { MapContainer, TileLayer, Marker, Popup, CircleMarker, Circle } from 'react-leaflet';\nimport L from 'leaflet';\nimport { Map as MapIcon, Droplet, ShieldPlus } from 'lucide-react';\n\n// Fix default Leaflet marker icons in Vite/React\ndelete (L.Icon.Default.prototype as any)._getIconUrl;\nL.Icon.Default.mergeOptions({\n    iconRetinaUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon-2x.png',\n    iconUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon.png',\n    shadowUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-shadow.png',\n});\n\nconst hydrantIcon = new L.Icon({\n    iconUrl: 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-blue.png',\n    shadowUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-shadow.png',\n    iconSize: [25, 41], iconAnchor: [12, 41], popupAnchor: [1, -34],\n});\n\nconst stationIcon = new L.Icon({\n    iconUrl: 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-green.png',\n    shadowUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-shadow.png',\n    iconSize: [25, 41], iconAnchor: [12, 41], popupAnchor: [1, -34],\n});\n\ntype Incident = {\n    id: number; incidentDate: string; incidentTime: string; barangay: string;\n    cause?: string; latitude: number; longitude: number; estimatedDamage?: number;\n    casualties?: number; injuries?: number; propertyType?: string; remarks?: string;\n};\n\n// Fire hydrant locations in Malvar (sample data)\nconst HYDRANTS = [\n    { id: 1, lat: 14.0415, lng: 121.1575, name: 'Hydrant - Poblacion' },\n    { id: 2, lat: 14.0390, lng: 121.1560, name: 'Hydrant - San Fernando' },\n    { id: 3, lat: 14.0435, lng: 121.1600, name: 'Hydrant - San Pedro I' },\n    { id: 4, lat: 14.0380, lng: 121.1540, name: 'Hydrant - Luta del Sur' },\n    { id: 5, lat: 14.0450, lng: 121.1620, name: 'Hydrant - Bilucao' },\n];\n\n// BFP stations in the area\nconst STATIONS = [\n    { id: 1, lat: 14.0412, lng: 121.1583, name: 'BFP Malvar Fire Station' },\n    { id: 2, lat: 14.0500, lng: 121.1650, name: 'BFP Sub-Station Bulihan' },\n];\n\nexport default function IncidentMap() {\n    const [incidents, setIncidents] = useState<Incident[]>([]);\n    const [loading, setLoading] = useState(true);\n    const [selectedBarangay, setSelectedBarangay] = useState('All');\n    const [showHydrants, setShowHydrants] = useState(true);\n    const [showStations, setShowStations] = useState(true);\n    const [showHeatmap, setShowHeatmap] = useState(true);\n    const [showIncidents, setShowIncidents] = useState(true);\n\n    useEffect(() => {\n        async function fetchIncidents() {\n            try {\n                setLoading(true);\n                const res = await api.get('/incidents');\n                setIncidents(res.data);\n            } catch (error) {\n                console.error(error);\n            } finally {\n                setLoading(false);\n            }\n        }\n        fetchIncidents();\n    }, []);\n\n    const barangayOptions = useMemo(() => {\n        const uniqueBarangays = Array.from(\n            new Set(incidents.map((i) => i.barangay).filter(Boolean)),\n        ).sort();\n        return ['All', ...uniqueBarangays];\n    }, [incidents]);\n\n    const filteredIncidents = useMemo(() => {\n        if (selectedBarangay === 'All') return incidents;\n        return incidents.filter((i) => i.barangay === selectedBarangay);\n    }, [incidents, selectedBarangay]);\n\n    // Compute heatmap clusters - group incidents by proximity\n    const heatmapPoints = useMemo(() => {\n        const clusters: { lat: number; lng: number; count: number; barangay: string }[] = [];\n        const barangayGroups: Record<string, { lats: number[]; lngs: number[]; count: number }> = {};\n\n        filteredIncidents.forEach((i) => {\n            if (!barangayGroups[i.barangay]) {\n                barangayGroups[i.barangay] = { lats: [], lngs: [], count: 0 };\n            }\n            barangayGroups[i.barangay].lats.push(Number(i.latitude));\n            barangayGroups[i.barangay].lngs.push(Number(i.longitude));\n            barangayGroups[i.barangay].count++;\n        });\n\n        Object.entries(barangayGroups).forEach(([barangay, group]) => {\n            const avgLat = group.lats.reduce((a, b) => a + b, 0) / group.lats.length;\n            const avgLng = group.lngs.reduce((a, b) => a + b, 0) / group.lngs.length;\n            clusters.push({ lat: avgLat, lng: avgLng, count: group.count, barangay });\n        });\n\n        return clusters;\n    }, [filteredIncidents]);\n\n    const defaultCenter: [number, number] = [14.0412, 121.1583];\n\n    return (\n        <div className=\"p-6\">\n            <div className=\"flex items-center gap-3 mb-2\">\n                <MapIcon className=\"w-8 h-8 text-blue-700\" />\n                <h2 className=\"text-2xl font-bold text-gray-800\">Smart Fire Incident Map</h2>\n            </div>\n            <p className=\"text-gray-600 mb-4\">Visualize fire incidents, hydrants, and BFP stations in Malvar.</p>\n\n            <div className=\"flex flex-wrap gap-4 mb-4 items-center\">\n                <div>\n                    <label className=\"text-sm font-medium text-gray-700 mr-2\">Barangay:</label>\n                    <select value={selectedBarangay} onChange={(e) => setSelectedBarangay(e.target.value)}\n                        className=\"border rounded-lg px-3 py-2 text-sm\">\n                        {barangayOptions.map((b) => <option key={b} value={b}>{b}</option>)}\n                    </select>\n                </div>\n\n                <label className=\"flex items-center gap-2 text-sm\">\n                    <input type=\"checkbox\" checked={showIncidents} onChange={(e) => setShowIncidents(e.target.checked)} />\n                    🔴 Incidents ({filteredIncidents.length})\n                </label>\n                <label className=\"flex items-center gap-2 text-sm\">\n                    <input type=\"checkbox\" checked={showHeatmap} onChange={(e) => setShowHeatmap(e.target.checked)} />\n                    🟠 Hotspots\n                </label>\n                <label className=\"flex items-center gap-2 text-sm\">\n                    <input type=\"checkbox\" checked={showHydrants} onChange={(e) => setShowHydrants(e.target.checked)} />\n                    🔵 Hydrants\n                </label>\n                <label className=\"flex items-center gap-2 text-sm\">\n                    <input type=\"checkbox\" checked={showStations} onChange={(e) => setShowStations(e.target.checked)} />\n                    🟢 BFP Stations\n                </label>\n            </div>\n\n            {loading ? (\n                <p>Loading map...</p>\n            ) : (\n                <MapContainer center={defaultCenter} zoom={13}\n                    style={{ height: '550px', width: '100%', borderRadius: '12px', overflow: 'hidden' }}>\n                    <TileLayer\n                        attribution='&copy; OpenStreetMap contributors'\n                        url=\"https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png\"\n                    />\n\n                    {/* Heatmap layer - circles showing hotspots */}\n                    {showHeatmap && heatmapPoints.map((point) => (\n                        <Circle key={`heat-${point.barangay}`}\n                            center={[point.lat, point.lng]}\n                            radius={200 + point.count * 80}\n                            pathOptions={{\n                                color: 'transparent',\n                                fillColor: point.count >= 5 ? '#dc2626' : point.count >= 3 ? '#f97316' : '#fbbf24',\n                                fillOpacity: 0.3,\n                            }}>\n                            <Popup>\n                                <strong>{point.barangay}</strong><br />\n                                {point.count} incident(s) — {point.count >= 5 ? 'HIGH RISK' : point.count >= 3 ? 'MODERATE RISK' : 'LOW RISK'}\n                            </Popup>\n                        </Circle>\n                    ))}\n\n                    {/* Incident markers */}\n                    {showIncidents && filteredIncidents.map((incident) => (\n                        <CircleMarker key={`inc-${incident.id}`}\n                            center={[Number(incident.latitude), Number(incident.longitude)]}\n                            radius={6}\n                            pathOptions={{ color: '#dc2626', fillColor: '#ef4444', fillOpacity: 0.8 }}>\n                            <Popup>\n                                <div style={{ minWidth: '200px' }}>\n                                    <p><strong>Barangay:</strong> {incident.barangay}</p>\n                                    <p><strong>Date:</strong> {incident.incidentDate}</p>\n                                    <p><strong>Time:</strong> {incident.incidentTime}</p>\n                                    <p><strong>Cause:</strong> {incident.cause || 'N/A'}</p>\n                                    <p><strong>Damage:</strong> ₱{incident.estimatedDamage ?? 0}</p>\n                                    <p><strong>Casualties:</strong> {incident.casualties ?? 0}</p>\n                                    <p><strong>Injuries:</strong> {incident.injuries ?? 0}</p>\n                                </div>\n                            </Popup>\n                        </CircleMarker>\n                    ))}\n\n                    {/* Fire hydrants */}\n                    {showHydrants && HYDRANTS.map((h) => (\n                        <Marker key={`hyd-${h.id}`} position={[h.lat, h.lng]} icon={hydrantIcon}>\n                            <Popup>\n                                <div className=\"flex items-center gap-1 mb-1\">\n                                    <Droplet className=\"w-4 h-4 text-blue-500\" />\n                                    <strong>{h.name}</strong>\n                                </div>\n                                Fire Hydrant\n                            </Popup>\n                        </Marker>\n                    ))}\n\n                    {/* BFP stations */}\n                    {showStations && STATIONS.map((s) => (\n                        <Marker key={`stn-${s.id}`} position={[s.lat, s.lng]} icon={stationIcon}>\n                            <Popup>\n                                <div className=\"flex items-center gap-1 mb-1\">\n                                    <ShieldPlus className=\"w-4 h-4 text-green-600\" />\n                                    <strong>{s.name}</strong>\n                                </div>\n                                BFP Fire Station\n                            </Popup>\n                        </Marker>\n                    ))}\n                </MapContainer>\n            )}\n\n            {/* Legend */}\n            <div className=\"mt-4 bg-white border rounded-xl p-4 flex flex-wrap gap-6 text-sm\">\n                <span className=\"font-semibold\">Legend:</span>\n                <span className=\"flex items-center gap-1\"><span className=\"w-3 h-3 rounded-full bg-red-500 inline-block\" /> Fire Incident</span>\n                <span className=\"flex items-center gap-1\"><span className=\"w-3 h-3 rounded-full bg-red-300 inline-block\" style={{ opacity: 0.4 }} /> High Risk Zone</span>\n                <span className=\"flex items-center gap-1\"><span className=\"w-3 h-3 rounded-full bg-orange-300 inline-block\" style={{ opacity: 0.4 }} /> Moderate Risk</span>\n                <span className=\"flex items-center gap-1\"><span className=\"w-3 h-3 rounded-full bg-yellow-300 inline-block\" style={{ opacity: 0.4 }} /> Low Risk</span>\n                <span className=\"flex items-center gap-1\"><span className=\"w-3 h-3 rounded-full bg-blue-500 inline-block\" /> Fire Hydrant</span>\n                <span className=\"flex items-center gap-1\"><span className=\"w-3 h-3 rounded-full bg-green-500 inline-block\" /> BFP Station</span>\n            </div>\n        </div>\n    );\n}","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Brian\\Desktop\\mysunog\\mysunog-frontend\\src\\pages\\InspectionRequest.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Brian\\Desktop\\mysunog\\mysunog-frontend\\src\\pages\\Login.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Brian\\Desktop\\mysunog\\mysunog-frontend\\src\\pages\\MyPermits.tsx","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":5,"column":44,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":5,"endColumn":47,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[170,173],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[170,173],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useEffect, useState } from 'react';\r\nimport { api } from '../services/api';\r\n\r\nexport default function MyPermits() {\r\n    const [permits, setPermits] = useState<any[]>([]);\r\n\r\n    useEffect(() => {\r\n        api.get('/permits/mine')\r\n            .then((res) => setPermits(res.data))\r\n            .catch((err) => {\r\n                console.error(err);\r\n                alert('Failed to load permits');\r\n            });\r\n    }, []);\r\n\r\n    return (\r\n        <div style={{ padding: 24 }}>\r\n            <h2>My Permit Requests</h2>\r\n\r\n            {permits.length === 0 ? (\r\n                <p>No permit requests found.</p>\r\n            ) : (\r\n                permits.map((permit) => (\r\n                    <div\r\n                        key={permit.id}\r\n                        style={{\r\n                            border: '1px solid #ccc',\r\n                            padding: 12,\r\n                            marginBottom: 12,\r\n                            borderRadius: 8,\r\n                        }}\r\n                    >\r\n                        <p><strong>Business Name:</strong> {permit.businessName}</p>\r\n                        <p><strong>Address:</strong> {permit.businessAddress}</p>\r\n                        <p><strong>Purpose:</strong> {permit.purpose}</p>\r\n                        <p><strong>Status:</strong> {permit.status}</p>\r\n                        <p><strong>Remarks:</strong> {permit.adminRemarks ?? 'None'}</p>\r\n                    </div>\r\n                ))\r\n            )}\r\n        </div>\r\n    );\r\n}","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Brian\\Desktop\\mysunog\\mysunog-frontend\\src\\pages\\Notifications.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Brian\\Desktop\\mysunog\\mysunog-frontend\\src\\pages\\PermitSubmit.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Brian\\Desktop\\mysunog\\mysunog-frontend\\src\\pages\\Reports.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Brian\\Desktop\\mysunog\\mysunog-frontend\\src\\pages\\VolunteerRegister.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Brian\\Desktop\\mysunog\\mysunog-frontend\\src\\services\\api.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]}]
